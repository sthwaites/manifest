{
  "name": "manifest",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start --hostname 0.0.0.0 --port 3000",
    "test": "vitest",
    "sandbox:init": "bash scripts/init-sandbox-git.sh",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit && npm --prefix sandbox run typecheck",
    "test:run": "vitest --run",
    "verify": "npm run lint && npm run typecheck && npm run security:audit && npm run test:run && npm run build && npm --prefix sandbox run test:run && npm --prefix sandbox run build",
    "security:audit": "npm audit --omit=dev --audit-level=moderate && npm --prefix sandbox audit --omit=dev --audit-level=moderate"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.4",
    "@prisma/client": "^7.8.0",
    "@types/ws": "^8.18.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.1.2",
    "lucide-react": "^1.16.0",
    "next": "^16.2.6",
    "next-auth": "beta",
    "openai": "^6.39.0",
    "prisma": "^7.8.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.6.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.4.0",
    "eslint-config-next": "^16.2.6",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
