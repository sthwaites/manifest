{
  "name": "manifest",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "dev:local": "node scripts/start-local-dev.mjs",
    "build": "next build",
    "start": "next start --hostname 0.0.0.0 --port 3000",
    "start:container": "node scripts/start-container.mjs",
    "proxy": "node scripts/proxy-server.mjs",
    "test": "vitest",
    "sandbox:init": "bash scripts/init-sandbox-git.sh",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit && npm --prefix sandbox run typecheck",
    "test:run": "vitest --run",
    "smoke:local": "node scripts/smoke-local.mjs",
    "smoke:docker": "node scripts/smoke-docker.mjs",
    "verify": "npm run lint && npm run typecheck && npm run security:audit && npm run test:run && npm run build && npm --prefix sandbox run test:run && npm --prefix sandbox run build",
    "security:audit": "npm audit --omit=dev --audit-level=moderate && npm --prefix sandbox audit --omit=dev --audit-level=moderate"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.4",
    "@prisma/client": "^6.0.0",
    "@types/ws": "^8.18.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.1.2",
    "lucide-react": "^0.468.0",
    "next": "^15.0.0",
    "next-auth": "beta",
    "openai": "^4.77.0",
    "prisma": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "jsdom": "^25.0.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
