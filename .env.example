# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit it.

# OpenAI
OPENAI_API_KEY=sk-...
CODEX_API_KEY=sk-...           # same value as OPENAI_API_KEY — used by codex binary for headless auth

# NextAuth
NEXTAUTH_SECRET=               # generate: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000

# Auth0 (Google OAuth)
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_ISSUER=https://<your-domain>.auth0.com

# Set to "true" to bypass Google auth locally (never set in production)
DEBUG_AUTH=false

# Database
DATABASE_URL=file:../data/dev.db

# Sandbox routing
# Local dev / Docker Compose defaults:
NEXT_PUBLIC_SANDBOX_PUBLIC_URL=http://localhost:3001/
SANDBOX_INTERNAL_URL=http://localhost:3001

# Fly single-container defaults:
# NEXT_PUBLIC_SANDBOX_PUBLIC_URL=/sandbox/
# SANDBOX_INTERNAL_URL=http://localhost:3001/sandbox
# SANDBOX_BASE_PATH=/sandbox
# NEXT_PUBLIC_SANDBOX_BASE_PATH=/sandbox
